# =============================================================================
# Rejv Last Episodes Sync – variables de entorno
# Copia este archivo a .env y rellena los valores.
# Para sincronizar con AzuraCast necesitas UNA de: SFTP, LOCAL_MEDIA_PATH o API.
# =============================================================================

# --- Subida por SFTP (recomendado si no estás en el mismo servidor) ---
# AzuraCast expone SFTP en instalaciones Docker. Sin límite 413.
AZURACAST_SFTP_HOST=
AZURACAST_SFTP_PORT=22
AZURACAST_SFTP_USER=
AZURACAST_SFTP_PASSWORD=
# Ruta remota donde están los medios (ej: /media/retransmision o la que indique AzuraCast)
AZURACAST_SFTP_REMOTE_PATH=
# Opcional: si defines también AZURACAST_API_KEY, tras subir por SFTP se reinicia la estación para que cargue los cambios

# --- Mismo servidor que AzuraCast: copia directa a disco ---
# Ruta absoluta de la carpeta de medios (o subcarpeta).
# Ejemplo: /var/azuracast/stations/radio_espai_jove/media/retransmision
AZURACAST_LOCAL_MEDIA_PATH=

# --- Subida por API (otro servidor o sin acceso al disco) ---
# API Key: panel AzuraCast → My API Keys (permiso "Manage Station Media")
AZURACAST_API_KEY=
# URL base de AzuraCast (solo si usas API)
AZURACAST_URL=https://live.radioespaijove.es
# ID de estación (opcional; si no se define, se usa la primera)
AZURACAST_STATION_ID=
# Carpeta dentro de la estación, ej: retransmision (solo API)
AZURACAST_UPLOAD_PATH=

# --- Notificaciones ---
# Webhook de Discord para mensaje al terminar (éxito o error)
DISCORD_WEBHOOK_URL=

# --- Descargas: reducir 500 por saturación ---
# Pausa en ms entre cada podcast (ej: 2000 = 2 s). Si ves muchos 500, prueba 2000-3000.
# DOWNLOAD_DELAY_MS=2000
# Timeout por archivo en ms (por defecto 120000 = 2 min)
# DOWNLOAD_TIMEOUT_MS=120000

# --- Opcional: test sin tocar AzuraCast ---
# DRY_RUN=1  → solo descarga, no sync ni Discord
